// EmPay — Prisma Schema
// Phase 1 baseline: shared models for Admin / HR / Payroll Officer / Employee modules.
// Each module owner can extend their slice as they implement features.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum UserRole {
  ADMIN
  HR_OFFICER
  PAYROLL_OFFICER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  REGULARIZED
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  PAID_LEAVE
  UNPAID_LEAVE
  SICK_LEAVE
  CASUAL_LEAVE
  MATERNITY_LEAVE
  PATERNITY_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayslipStatus {
  DRAFT
  GENERATED
  REVISED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

// ============================================
// Auth & Identity
// ============================================

// Admin uses `email` to sign in. HR / Payroll / Employee use auto-generated `loginId`.
// `email` is always populated (used for password reset / communications).
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  loginId            String?  @unique
  passwordHash       String
  name               String
  role               UserRole
  mustChangePassword Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee          Employee?
  approvedLeaves    Leave[]            @relation("LeaveApprover")
  raisedDisputes    PayslipDispute[]   @relation("DisputeRaiser")
  resolvedDisputes  PayslipDispute[]   @relation("DisputeResolver")
  createdPayslips   Payslip[]          @relation("PayslipCreator")

  @@index([role])
}

// ============================================
// Employee profile (1-to-1 with User for non-admin roles)
// ============================================

model Employee {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  phone        String?
  department   String?
  position     String?
  joinDate     DateTime
  dob          DateTime?
  basicSalary  Decimal        @db.Decimal(12, 2)
  status       EmployeeStatus @default(ACTIVE)
  avatarUrl    String?

  // Bank details (employee can self-edit per task list)
  bankName       String?
  bankAccountNo  String?
  bankIfsc       String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  attendance        Attendance[]
  leaves            Leave[]
  leaveAllocations  LeaveAllocation[]
  payslips          Payslip[]

  @@index([department])
  @@index([status])
}

// ============================================
// Attendance
// ============================================

model Attendance {
  id           String           @id @default(uuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date         DateTime         @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  hoursWorked  Decimal?         @db.Decimal(5, 2)
  status       AttendanceStatus
  notes        String?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  regularization AttendanceRegularization?

  @@unique([employeeId, date])
  @@index([date])
}

model AttendanceRegularization {
  id            String                @id @default(uuid())
  attendanceId  String                @unique
  attendance    Attendance            @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  reason        String
  status        RegularizationStatus  @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

// ============================================
// Leave (Time Off)
// ============================================

model LeaveAllocation {
  id              String     @id @default(uuid())
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type            LeaveType
  year            Int
  totalDays       Decimal    @db.Decimal(5, 2)
  usedDays        Decimal    @default(0) @db.Decimal(5, 2)
  carriedForward  Decimal    @default(0) @db.Decimal(5, 2)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([employeeId, type, year])
}

model Leave {
  id            String       @id @default(uuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type          LeaveType
  startDate     DateTime     @db.Date
  endDate       DateTime     @db.Date
  days          Decimal      @db.Decimal(5, 2)
  reason        String
  status        LeaveStatus  @default(PENDING)

  approvedById  String?
  approvedBy    User?        @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  reviewNote    String?

  attachmentUrl String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([startDate])
}

// ============================================
// Payroll — Payslip & Disputes
// (Payroll Officer module owner: extend fields as you implement the calculation engine)
// ============================================

model Payslip {
  id             String         @id @default(uuid())
  employeeId     String
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month          Int            // 1-12
  year           Int
  version        Int            @default(1)

  basicSalary    Decimal        @db.Decimal(12, 2)
  grossSalary    Decimal        @db.Decimal(12, 2)
  totalDeductions Decimal       @db.Decimal(12, 2)
  netSalary      Decimal        @db.Decimal(12, 2)

  // Detailed line items — extend in your slice
  earnings       Json?          // [{ label, amount }]
  deductions     Json?          // [{ label, amount }]

  status         PayslipStatus  @default(DRAFT)
  pdfUrl         String?

  createdById    String?
  createdBy      User?          @relation("PayslipCreator", fields: [createdById], references: [id])

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  disputes       PayslipDispute[]

  @@unique([employeeId, month, year, version])
  @@index([month, year])
}

model PayslipDispute {
  id            String         @id @default(uuid())
  payslipId     String
  payslip       Payslip        @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  raisedById    String
  raisedBy      User           @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason        String

  status        DisputeStatus  @default(OPEN)
  resolution    String?
  resolvedById  String?
  resolvedBy    User?          @relation("DisputeResolver", fields: [resolvedById], references: [id])
  resolvedAt    DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
}
