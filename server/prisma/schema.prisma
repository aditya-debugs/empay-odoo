generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres.rdnllksxoaeokmkwdape:Ashpikachu%401641@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  loginId            String?          @unique
  passwordHash       String
  name               String
  role               UserRole
  companyName        String?
  phone              String?
  mustChangePassword Boolean          @default(false)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  employee           Employee?
  approvedLeaves     Leave[]          @relation("LeaveApprover")
  createdPayslips    Payslip[]        @relation("PayslipCreator")
  raisedDisputes     PayslipDispute[] @relation("DisputeRaiser")
  resolvedDisputes   PayslipDispute[] @relation("DisputeResolver")

  @@index([role])
}

model Employee {
  id               String            @id @default(uuid())
  userId           String            @unique
  firstName        String
  lastName         String
  phone            String?
  personalEmail    String?
  personalPhone    String?
  gender           Gender?
  department       String?
  position         String?
  joinDate         DateTime
  dob              DateTime?
  employmentType   EmploymentType    @default(FULL_TIME)
  status           EmployeeStatus    @default(ACTIVE)
  avatarUrl        String?
  resumeUrl        String?
  skills           String[]          @default([])
  certificates     String[]          @default([])
  aboutMe          String?
  basicSalary      Decimal           @db.Decimal(12, 2)
  hra              Decimal?          @db.Decimal(12, 2)
  conveyance       Decimal?          @db.Decimal(12, 2)
  specialAllowance Decimal?          @db.Decimal(12, 2)
  otherAllowance   Decimal?          @db.Decimal(12, 2)
  pfEnabled        Boolean           @default(true)
  pfPercent        Decimal?          @db.Decimal(5, 2)
  professionalTax  Decimal?          @db.Decimal(8, 2)
  pan              String?
  aadhaar          String?
  bankName         String?
  bankBranch       String?
  bankAccountNo    String?
  bankIfsc         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendance       Attendance[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves           Leave[]
  leaveAllocations LeaveAllocation[]
  payslips         Payslip[]

  @@index([department])
  @@index([status])
}

model OrgSettings {
  id                   String   @id @default(uuid())
  companyName          String   @default("EmPay")
  companyAddress       String?
  cin                  String?
  logoUrl              String?
  fyStartMonth         Int      @default(4)
  payDay               Int      @default(28)
  workingDaysPerMonth  Int      @default(26)
  workingDaysPerWeek   Int      @default(5)
  weeklyOff            String   @default("SAT_SUN")
  isMetro              Boolean  @default(false)
  metroHraPercent      Decimal  @default(50) @db.Decimal(5, 2)
  nonMetroHraPercent   Decimal  @default(40) @db.Decimal(5, 2)
  conveyanceDefault    Decimal  @default(1600) @db.Decimal(10, 2)
  medicalDefault       Decimal  @default(1250) @db.Decimal(10, 2)
  pfEnabled            Boolean  @default(true)
  pfBasicThreshold     Decimal  @default(15000) @db.Decimal(12, 2)
  pfEmployeePercent    Decimal  @default(12) @db.Decimal(5, 2)
  pfEmployerPercent    Decimal  @default(12) @db.Decimal(5, 2)
  esicEnabled          Boolean  @default(true)
  esicGrossThreshold   Decimal  @default(21000) @db.Decimal(12, 2)
  esicEmployeePercent  Decimal  @default(0.75) @db.Decimal(5, 4)
  esicEmployerPercent  Decimal  @default(3.25) @db.Decimal(5, 4)
  profTaxState         String   @default("MAHARASHTRA")
  fullDayMinHours      Decimal  @default(8) @db.Decimal(4, 2)
  halfDayMinHours      Decimal  @default(4) @db.Decimal(4, 2)
  graceMinutes         Int      @default(15)
  fullDayCheckInBefore String   @default("10:00")
  halfDayCheckInBefore String   @default("11:00")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Attendance {
  id             String                    @id @default(uuid())
  employeeId     String
  date           DateTime                  @db.Date
  checkIn        DateTime?
  checkOut       DateTime?
  hoursWorked    Decimal?                  @db.Decimal(10, 6)
  status         AttendanceStatus
  notes          String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  employee       Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  AttendanceLog  AttendanceLog[]
  regularization AttendanceRegularization?

  @@unique([employeeId, date])
  @@index([date])
}

model AttendanceRegularization {
  id           String               @id @default(uuid())
  attendanceId String               @unique
  reason       String
  status       RegularizationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  attendance   Attendance           @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model LeaveAllocation {
  id             String    @id @default(uuid())
  employeeId     String
  type           LeaveType
  year           Int
  totalDays      Decimal   @db.Decimal(5, 2)
  usedDays       Decimal   @default(0) @db.Decimal(5, 2)
  carriedForward Decimal   @default(0) @db.Decimal(5, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, type, year])
}

model Leave {
  id            String      @id @default(uuid())
  employeeId    String
  type          LeaveType
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  days          Decimal     @db.Decimal(5, 2)
  reason        String
  status        LeaveStatus @default(PENDING)
  approvedById  String?
  approvedAt    DateTime?
  reviewNote    String?
  attachmentUrl String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  approvedBy    User?       @relation("LeaveApprover", fields: [approvedById], references: [id])
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([startDate])
}

model Payslip {
  id              String           @id @default(uuid())
  employeeId      String
  month           Int
  year            Int
  version         Int              @default(1)
  workingDays     Int?
  paidDays        Decimal?         @db.Decimal(5, 2)
  lopDays         Decimal?         @db.Decimal(5, 2)
  basicSalary     Decimal          @db.Decimal(12, 2)
  grossSalary     Decimal          @db.Decimal(12, 2)
  totalDeductions Decimal          @db.Decimal(12, 2)
  netSalary       Decimal          @db.Decimal(12, 2)
  cappedAtZero    Boolean          @default(false)
  earnings        Json?
  deductions      Json?
  status          PayslipStatus    @default(DRAFT)
  pdfUrl          String?
  createdById     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       User?            @relation("PayslipCreator", fields: [createdById], references: [id])
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  disputes        PayslipDispute[]

  @@unique([employeeId, month, year, version])
  @@index([month, year])
}

model PayslipDispute {
  id           String        @id @default(uuid())
  payslipId    String
  raisedById   String
  reason       String
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  routedTo     DisputeRoute  @default(PAYROLL)
  payslip      Payslip       @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  raisedBy     User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  resolvedBy   User?         @relation("DisputeResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([routedTo])
}

model AttendanceLog {
  id           String     @id
  attendanceId String
  type         LogType
  timestamp    DateTime   @default(now())
  Attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  HR_OFFICER
  PAYROLL_OFFICER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  REGULARIZED
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  PAID_LEAVE
  UNPAID_LEAVE
  SICK_LEAVE
  CASUAL_LEAVE
  MATERNITY_LEAVE
  PATERNITY_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayslipStatus {
  DRAFT
  GENERATED
  REVISED
  COMPUTED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum DisputeRoute {
  PAYROLL
  HR
}

enum LogType {
  IN
  OUT
}
