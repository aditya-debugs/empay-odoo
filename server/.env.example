# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/empay?sslmode=require

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS
CLIENT_URL=http://localhost:5173

# Email (future)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Bootstrap admin (auto-created on server start if no admin exists in DB)
# Override these to set your own default credentials.
BOOTSTRAP_ADMIN_EMAIL=admin@empay.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_NAME=Bootstrap Admin
